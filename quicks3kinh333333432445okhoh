local viewModel = require(vmMod)

local origCreateVM = clientItem._CreateViewModel
clientItem._CreateViewModel = function(self, vmRef)
if config.unlockAll and vmRef and self.ClientFighter and self.ClientFighter.Player == localPlayer then
	local weaponEquipped = equipped[self.Name]
	if weaponEquipped then
		local dataKey = self:ToEnum("Data")
		local data = vmRef[dataKey]
		if data then
			if weaponEquipped.Skin then
				data[self:ToEnum("Skin")] = weaponEquipped.Skin
				data[self:ToEnum("Name")] = weaponEquipped.Skin.Name
			end
			if weaponEquipped.Charm then
				data[self:ToEnum("Charm")] = weaponEquipped.Charm
			end
		end
	end
end
return origCreateVM(self, vmRef)
end

local origGetWrap = viewModel.GetWrap
viewModel.GetWrap = function(self)
if config.unlockAll then
	local item = self.ClientItem
	if item and item.ClientFighter and item.ClientFighter.Player == localPlayer then
		local weaponEquipped = equipped[item.Name]
		if weaponEquipped and weaponEquipped.Wrap then
			return weaponEquipped.Wrap
		end
	end
end
return origGetWrap(self)
end
end)

-- DataController patches
local originalGetWeaponData = dataCtrl.GetWeaponData
dataCtrl.GetWeaponData = function(self, weaponName)
if not config.unlockAll then return originalGetWeaponData(self, weaponName) end
if spoofCache[weaponName] then return spoofCache[weaponName] end

local realData = originalGetWeaponData(self, weaponName)
local spoofed = { Unlocked = true, Level = 100, XP = 99999, Name = weaponName }

if realData then
	for k, v in pairs(realData) do spoofed[k] = v end
end
spoofed.Unlocked = true

if equipped[weaponName] then
	for k, v in pairs(equipped[weaponName]) do spoofed[k] = v end
end

spoofCache[weaponName] = spoofed
return spoofed
end

local cosmeticMetatable = { __index = function() return true end }
local spoofedCosmetics  = setmetatable({}, cosmeticMetatable)

local originalGet = dataCtrl.Get
dataCtrl.Get = function(self, key)
if config.unlockAll then
	if key == "WeaponInventory"  then return equipped end
	if key == "CosmeticInventory" or key == "OwnedWeapons" then return spoofedCosmetics end
end
return originalGet(self, key)
end

local originalGetUnlocked = dataCtrl.GetUnlockedWeapons
dataCtrl.GetUnlockedWeapons = function(self, ...)
if config.unlockAll then
	local weapons = {}
	for name in pairs(itemLib.Items) do weapons[name] = true end
	return weapons
end
return originalGetUnlocked(self, ...)
end

if dataCtrl.CurrentData then
	local oldRep = dataCtrl.CurrentData.Replicate
	dataCtrl.CurrentData.Replicate = function(self, key, ...)
	if config.unlockAll and (key == "WeaponInventory" or key == "OwnedWeapons") then
		return
	end
	return oldRep(self, key, ...)
end
end

