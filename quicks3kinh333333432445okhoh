local oldNC
oldNC = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
local method = getnamecallmethod()

if method == "FireServer" and self.Name == "EquipCosmetic" then
	if not config.unlockAll then return oldNC(self, ...) end

	local args = {...}
	local weaponName, cosmeticType, cosmeticName, options = args[1], args[2], args[3], args[4]

	equipped[weaponName] = equipped[weaponName] or {}

	if not cosmeticName or cosmeticName == "" or cosmeticName == "None" then
		equipped[weaponName][cosmeticType] = nil
	else
		local base = cosmeticLib.Cosmetics[cosmeticName]
		if base then
			local cloned = {
			Name     = cosmeticName,
			Seed     = math.random(1, 1e6),
			Inverted = options and options.IsInverted or false
			}
			for k, v in pairs(base) do cloned[k] = v end
			equipped[weaponName][cosmeticType] = cloned
		end
	end

	spoofCache[weaponName] = nil
	saveSettings()

	if dataCtrl.CurrentData then
		dataCtrl.CurrentData:Replicate("WeaponInventory")
	end
	return
end

return oldNC(self, ...)
end))

