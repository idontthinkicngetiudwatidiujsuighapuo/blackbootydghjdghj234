local function saveSettings()
	local ok, content = pcall(h.JSONEncode, h, {
	Skins = equipped,
	UnlockToggle = config.unlockAll
	})
	if ok then writefile(fileName, content) end
end

local function loadSettings()
	if isfile(fileName) then
		local ok, decoded = pcall(function() return h:JSONDecode(readfile(fileName)) end)
		if ok and decoded then
			equipped = decoded.Skins or {}
			config.unlockAll = decoded.UnlockToggle
			_Enabled = config.unlockAll  -- Sync toggle with saved config
		end
	end
end

