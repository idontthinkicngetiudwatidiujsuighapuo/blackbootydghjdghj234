-- LOGIC FUNCTIONS
local function SaveConfig()
    if writefile then
        local success, err = pcall(function()
            writefile(CONFIG_FILE, HttpService:JSONEncode({Enabled = _Enabled}))
        end)
    end
end

local function LoadConfig()
    if isfile and isfile(CONFIG_FILE) then
        local success, result = pcall(function()
            return HttpService:JSONDecode(readfile(CONFIG_FILE))
        end)
        if success and result.Enabled ~= nil then
            _Enabled = result.Enabled
        end
    end
end

local function UpdateToggleVisuals(instant)
    local t = instant and 0 or 0.4
    local info = TweenInfo.new(t, Enum.EasingStyle.Quart)
    
    local color = _Enabled and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(30, 30, 30)
    local glow = _Enabled and 0.5 or 1
    local stroke = _Enabled and 0 or 0.8
    
    TweenService:Create(ToggleBox, info, {BackgroundColor3 = color}):Play()
    TweenService:Create(ToggleGlow, info, {ImageTransparency = glow}):Play()
    TweenService:Create(ToggleStroke, info, {Transparency = stroke}):Play()
end

local function ToggleMenu()
    _Visible = not _Visible
    -- Slow Bouncy Animation (1.4s)
    local targetY = _Visible and -12 or -180 
    local info = TweenInfo.new(1.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    
    TweenService:Create(ShadowFrame, info, {Position = UDim2.new(0.5, 0, 0, targetY)}):Play()
end

