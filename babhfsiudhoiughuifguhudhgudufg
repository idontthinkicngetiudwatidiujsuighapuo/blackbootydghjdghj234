                b.BackgroundColor3 = sk_blankBg
            end
        end
        btn.BackgroundColor3 = sk_accent
        stroke.Color = sk_accent
        
        sk_refreshSkins()
    end)
    
    table.insert(sk_weaponButtons, {btn = btn, dot = dot, weaponName = weapon})
    return btn
