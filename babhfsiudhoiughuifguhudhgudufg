-- Update all dots function
local function sk_updateAllDots()
    if not Flags["enable skins"] then return end
    
    for _, btn in ipairs(sk_weaponButtons) do
        if btn and btn.dot then
            local weaponName = btn.weaponName
            btn.dot.Visible = (sk_settings.ActiveSkins[weaponName] ~= nil)
        end
    end
    
    for _, btn in ipairs(sk_SkinScroll:GetChildren()) do
        if btn:IsA("TextButton") then
            local dot = btn:FindFirstChild("Dot")
            if dot then
                local skinName = btn:FindFirstChildOfClass("TextLabel")
                if skinName and skinName.Text then
                    local isEnabled = false
                    if skinName.Text == "Default" then
                        isEnabled = (sk_settings.ActiveSkins[sk_selectedWeapon] == nil)
                    else
                        isEnabled = (sk_settings.ActiveSkins[sk_selectedWeapon] == skinName.Text)
                    end
                    dot.Visible = isEnabled
                    btn.BackgroundColor3 = isEnabled and sk_accent or sk_blankBg
                end
            end
        end
    end
    
    for _, btn in ipairs(sk_WeaponScroll:GetChildren()) do
        if btn:IsA("TextButton") then
            local weaponName = btn:FindFirstChildOfClass("TextLabel")
            if weaponName and weaponName.Text then
                if weaponName.Text == sk_selectedWeapon then
                    btn.BackgroundColor3 = sk_accent
                else
                    btn.BackgroundColor3 = sk_blankBg
                end
            end
        end
    end
end

-- Weapon button creation
