-- Persistent updates for skin icons
local function startPersistentUpdates()
    task.spawn(function()
        while true do
            task.wait(0.5)
            if Flags["enable skins"] then
                -- Reapply skins to all UI elements
                for weapon, skin in pairs(sk_settings.ActiveSkins) do
                    sk_updateHotbarIcon(weapon, skin)
                    sk_updatePickWeaponsIcon(weapon, skin)
                    sk_updateEquipmentIcon(weapon, skin)
                end
                
                -- Reapply glass if enabled
                if sk_settings.GlassEnabled then
                    sk_applyGlassToViewModel()
                end
            end
        end
    end)
    
    -- Monitor for new weapons being equipped
    task.spawn(function()
        local playerGui = sk_localPlayer:WaitForChild("PlayerGui")
        local function checkForNewWeapons()
            if not Flags["enable skins"] then return end
            
            -- Check hotbar for new weapons
            local hotbar = playerGui:FindFirstChild("MainGui") and 
                          playerGui.MainGui:FindFirstChild("MainFrame") and
                          playerGui.MainGui.MainFrame:FindFirstChild("FighterInterfaces") and
                          playerGui.MainGui.MainFrame.FighterInterfaces:FindFirstChild(sk_playerName) and
                          playerGui.MainGui.MainFrame.FighterInterfaces[sk_playerName]:FindFirstChild("Hotbar") and
                          playerGui.MainGui.MainFrame.FighterInterfaces[sk_playerName].Hotbar:FindFirstChild("Container")
            
            if hotbar then
                for _, weapon in pairs(hotbar:GetChildren()) do
                    if sk_settings.ActiveSkins[weapon.Name] then
                        sk_updateHotbarIcon(weapon.Name, sk_settings.ActiveSkins[weapon.Name])
                    end
                end
            end
        end
        
        while true do
            task.wait(0.3)
            checkForNewWeapons()
        end
    end)
    
    -- Monitor for respawn
    task.spawn(function()
        sk_localPlayer.CharacterAdded:Connect(function()
            task.wait(1)
            if Flags["enable skins"] then
                for weapon, skin in pairs(sk_settings.ActiveSkins) do
                    sk_applySkin(weapon, skin, true)
                end
            end
        end)
    end)
end

-- Start the persistent updates
startPersistentUpdates()

