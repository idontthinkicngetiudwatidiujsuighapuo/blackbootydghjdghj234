-- Backup functions
local sk_backupFolder = sk_Lighting:FindFirstChild("SC_Backups") or Instance.new("Folder", sk_Lighting)
sk_backupFolder.Name = "SC_Backups"

local function sk_backupModel(modelName, model)
    if not model then return end
    if sk_backupFolder:FindFirstChild(modelName) then return end
    
    local backup = Instance.new("Folder")
    backup.Name = modelName
    for _, child in ipairs(model:GetChildren()) do
        local clone = child:Clone()
        if clone then
            clone.Parent = backup
        end
    end
    backup.Parent = sk_backupFolder
end

local function sk_restoreModel(target, backupName)
    local backup = sk_backupFolder:FindFirstChild(backupName)
    if not backup then return end
    
    target:ClearAllChildren()
    for _, child in ipairs(backup:GetChildren()) do
        child:Clone().Parent = target
    end
end

-- Main skin application function
local function sk_applySkin(weapon, skin, enable)
    if not weapon then return end
    if not Flags["enable skins"] then return end -- Check flag
    
    -- Find the weapon model in view models
    local weaponModel
    for _, v in ipairs(sk_viewModels:GetDescendants()) do
        if v.Name == weapon then
            weaponModel = v
            break
        end
    end
    if not weaponModel then return end
    
    if enable and skin then
        -- Find skin model
        local skinModel
        for _, v in ipairs(sk_viewModels:GetDescendants()) do
            if v.Name == skin then
                skinModel = v
                break
            end
        end
        if not skinModel then return end
        
        -- Backup original
        sk_backupModel(weapon, weaponModel)
        
        -- Apply skin
        weaponModel:ClearAllChildren()
        for _, child in ipairs(skinModel:GetChildren()) do
            child:Clone().Parent = weaponModel
        end
        
        -- Also apply to workspace model
        local workspaceModel = workspace:FindFirstChild(weapon)
        if workspaceModel then
            sk_backupModel(weapon .. "_ws", workspaceModel)
            local pivot = workspaceModel:GetPivot()
            workspaceModel:ClearAllChildren()
            for _, child in ipairs(skinModel:GetChildren()) do
                child:Clone().Parent = workspaceModel
            end
            workspaceModel:PivotTo(pivot)
        end
        
        sk_settings.ActiveSkins[weapon] = skin
        
        -- Update UI icons
        sk_updateHotbarIcon(weapon, skin)
        sk_updatePickWeaponsIcon(weapon, skin)
        sk_updateEquipmentIcon(weapon, skin)
        sk_updateCustomizeMenu(weapon, skin)
        
    else
        -- Restore original
        sk_restoreModel(weaponModel, weapon)
        
        local workspaceModel = workspace:FindFirstChild(weapon)
        if workspaceModel then
            local pivot = workspaceModel:GetPivot()
            sk_restoreModel(workspaceModel, weapon .. "_ws")
            workspaceModel:PivotTo(pivot)
        end
        
        sk_settings.ActiveSkins[weapon] = nil
        
        -- Restore UI icons
        sk_updateHotbarIcon(weapon, weapon)
        sk_updatePickWeaponsIcon(weapon, weapon)
        sk_updateEquipmentIcon(weapon, weapon)
        sk_updateCustomizeMenu(weapon, nil)
    end
    
    sk_saveConfig()
    sk_updateAllDots()
end

-- Glass material functions
local function sk_applyGlass(part, transparency)
    if not part then return end
    part.Material = Enum.Material.Glass
    part.Transparency = transparency / 100
    part.Reflectance = 0.1
end

local function sk_applyGlassToViewModel()
    if not sk_settings.GlassEnabled then return end
    
    local id = sk_ReplicatedStorage:FindFirstChild("Assets")
    if id then
        id = id:FindFirstChild("Temp")
        if id then
            id = id:FindFirstChild("ViewModels")
            if id then
                for _, vm in ipairs(id:GetChildren()) do
                    if string.find(vm.Name, sk_playerName .. " -", 1, true) == 1 then
                        local itemVisual = vm:FindFirstChild("ItemVisual")
                        if itemVisual then
                            for _, part in ipairs(itemVisual:GetDescendants()) do
                                if part:IsA("BasePart") or part:IsA("MeshPart") or part:IsA("Part") then
                                    sk_applyGlass(part, sk_settings.GlassTransparency)
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    
    local wsViewModels = workspace:FindFirstChild("ViewModels")
    if wsViewModels then
        local fp = wsViewModels:FindFirstChild("FirstPerson")
        if fp then
            for _, weapon in ipairs(fp:GetChildren()) do
                if weapon:IsA("Model") and weapon.Name:find(sk_playerName .. " -") then
                    for _, part in ipairs(weapon:GetDescendants()) do
                        if part:IsA("BasePart") or part:IsA("MeshPart") or part:IsA("Part") then
                            sk_applyGlass(part, sk_settings.GlassTransparency)
                        end
                    end
                end
            end
        end
    end
end

local function sk_removeGlassFromViewModel()
    local id = sk_ReplicatedStorage:FindFirstChild("Assets")
    if id then
        id = id:FindFirstChild("Temp")
        if id then
            id = id:FindFirstChild("ViewModels")
            if id then
                for _, vm in ipairs(id:GetChildren()) do
                    if string.find(vm.Name, sk_playerName .. " -", 1, true) == 1 then
                        local itemVisual = vm:FindFirstChild("ItemVisual")
                        if itemVisual then
                            for _, part in ipairs(itemVisual:GetDescendants()) do
                                if part:IsA("BasePart") or part:IsA("MeshPart") or part:IsA("Part") then
                                    part.Material = Enum.Material.Plastic
                                    part.Transparency = 0
                                    part.Reflectance = 0
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    
    local wsViewModels = workspace:FindFirstChild("ViewModels")
    if wsViewModels then
        local fp = wsViewModels:FindFirstChild("FirstPerson")
        if fp then
            for _, weapon in ipairs(fp:GetChildren()) do
                if weapon:IsA("Model") and weapon.Name:find(sk_playerName .. " -") then
                    for _, part in ipairs(weapon:GetDescendants()) do
                        if part:IsA("BasePart") or part:IsA("MeshPart") or part:IsA("Part") then
                            part.Material = Enum.Material.Plastic
                            part.Transparency = 0
                            part.Reflectance = 0
                        end
                    end
                end
            end
        end
    end
end

local function sk_updateGlass()
    if sk_settings.GlassEnabled then
        sk_applyGlassToViewModel()
    else
        sk_removeGlassFromViewModel()
    end
end

local function sk_setupGlassMonitor()
    local id = sk_ReplicatedStorage:FindFirstChild("Assets")
    if id then
        id = id:FindFirstChild("Temp")
        if id then
            id = id:FindFirstChild("ViewModels")
            if id then
                id.ChildAdded:Connect(function(child)
                    if sk_settings.GlassEnabled and string.find(child.Name, sk_playerName .. " -", 1, true) == 1 then
                        task.wait(0.1)
                        local itemVisual = child:FindFirstChild("ItemVisual")
                        if itemVisual then
                            for _, part in ipairs(itemVisual:GetDescendants()) do
                                if part:IsA("BasePart") or part:IsA("MeshPart") or part:IsA("Part") then
                                    sk_applyGlass(part, sk_settings.GlassTransparency)
                                end
                            end
                        end
                    end
                end)
            end
        end
    end
    
    local wsViewModels = workspace:FindFirstChild("ViewModels")
    if wsViewModels then
        local fp = wsViewModels:FindFirstChild("FirstPerson")
        if fp then
            fp.ChildAdded:Connect(function(weapon)
                if sk_settings.GlassEnabled and weapon:IsA("Model") and weapon.Name:find(sk_playerName .. " -") then
                    task.wait(0.1)
                    for _, part in ipairs(weapon:GetDescendants()) do
                        if part:IsA("BasePart") or part:IsA("MeshPart") or part:IsA("Part") then
                            sk_applyGlass(part, sk_settings.GlassTransparency)
                        end
                    end
                end
            end)
        end
    end
end

