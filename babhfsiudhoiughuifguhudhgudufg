-- Flag monitoring
local function sk_checkFlags()
    -- Get current flag values
    local shouldShow = Flags["show skin changer"]
    local shouldEnable = Flags["enable skins"]
    
    -- Update visibility
    if shouldShow and not sk_isVisible then
        sk_isVisible = true
        sk_ScreenGui.Enabled = true
        -- Smooth slide-in animation
        sk_TweenService:Create(sk_MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), 
            {Position = UDim2.new(0.5, 0, 0, sk_SHOW_POS)}):Play()
    elseif not shouldShow and sk_isVisible then
        sk_isVisible = false
        -- Smooth slide-out animation
        sk_TweenService:Create(sk_MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), 
            {Position = UDim2.new(0.5, 0, 0, sk_HIDE_POS)}):Play()
        -- Delay disabling GUI until animation completes
        task.delay(0.3, function()
            if not sk_isVisible then
                sk_ScreenGui.Enabled = false
            end
        end)
    end
    
    -- Update interactability based on enable flag
    local interactable = shouldEnable
    for _, child in ipairs(sk_MainFrame:GetDescendants()) do
        if child:IsA("TextButton") or child:IsA("TextBox") then
            child.Active = interactable
            child.Selectable = interactable
            -- Visual feedback when disabled
            if not interactable then
                child.BackgroundTransparency = 0.6
            else
                child.BackgroundTransparency = 0
            end
        end
    end
    
    -- Reset selections when skins are disabled
    if not shouldEnable then
        sk_selectedWeapon = nil
        sk_buildWeapons()
        for _, v in ipairs(sk_SkinScroll:GetChildren()) do
            if v:IsA("TextButton") then v:Destroy() end
        end
    end
end

