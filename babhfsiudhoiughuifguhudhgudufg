    end
end)




local function setupWatcher()
    if not viewModels then
        local success, result = pcall(function()
            return player:WaitForChild("PlayerScripts"):WaitForChild("Assets"):WaitForChild("ViewModels", 5)
        end)
        if success then
            viewModels = result
        else
            task.delay(1, setupWatcher)
            return
        end
    end
    

    viewModels.DescendantAdded:Connect(function(descendant)
        if getgenv().skinchanger then
            for weaponName, skinName in pairs(activeSkins) do
                if descendant.Name == weaponName then
                    applySkin(weaponName, skinName)
                    updateAllIcons()
                    break
                end
            end
        end
        
     
        if getgenv().glass and descendant:IsA("Model") then
            if string.find(descendant.Name, playerName) or descendant.Name == "ItemVisual" then
                task.wait(0.1)
                for _, part in pairs(descendant:GetDescendants()) do
                    applyGlassToPart(part)
                end
            end
        end
    end)
    

    local wsViewModels = workspace:FindFirstChild("ViewModels")
    if wsViewModels then
        local fp = wsViewModels:FindFirstChild("FirstPerson")
        if fp then
            fp.ChildAdded:Connect(function(weapon)
                if getgenv().glass and weapon:IsA("Model") and string.find(weapon.Name, playerName) then
                    task.wait(0.1)
                    for _, part in pairs(weapon:GetDescendants()) do
                        applyGlassToPart(part)
                    end
                end
            end)
        end
    end
end

setupWatcher()


player.CharacterAdded:Connect(function()
    task.wait(1) 
    if getgenv().skinchanger then
        for weaponName, skinName in pairs(activeSkins) do
            applySkin(weaponName, skinName)
        end
        updateAllIcons()
    end
    
    if getgenv().glass then
        applyGlassToAll()
    end
end)


