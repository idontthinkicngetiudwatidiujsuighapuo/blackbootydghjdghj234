-- Skin button creation
local function sk_createSkinButton(skinName, weaponName, order)
    local isDefault = (skinName == "Default")
    local isEnabled = isDefault and (sk_settings.ActiveSkins[weaponName] == nil) or (not isDefault and sk_settings.ActiveSkins[weaponName] == skinName)
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.fromOffset(80 * sk_uiScale, 86 * sk_uiScale)
    btn.BackgroundColor3 = isEnabled and sk_accent or sk_blankBg
    btn.BorderSizePixel = 0
    btn.Text = ""
    btn.LayoutOrder = order
    btn.Name = "SkinBtn_" .. skinName
    
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 7)
    
    local image = Instance.new("ImageLabel", btn)
    image.Size = UDim2.new(2, 0, 1, 0)
    image.Position = UDim2.new(0, -40 * sk_uiScale, 0, 0)
    image.BackgroundTransparency = 1
    image.ScaleType = Enum.ScaleType.Crop
    image.ZIndex = 1
    Instance.new("UICorner", image).CornerRadius = UDim.new(0, 7)
    
    if isDefault then
        image.Image = af[weaponName] or af["MISSING_SKIN"]
    else
        image.Image = af[skinName] or af["MISSING_SKIN"]
    end
    
    local label = Instance.new("TextLabel", btn)
    label.Size = UDim2.new(1, 0, 0, 20 * sk_uiScale)
    label.Position = UDim2.new(0, 0, 1, -20 * sk_uiScale)
    label.BackgroundTransparency = 1
    label.Text = skinName
    label.TextColor3 = sk_textColor
    label.TextSize = 9 * sk_uiScale
    label.Font = Enum.Font.GothamMedium
    label.TextTruncate = Enum.TextTruncate.AtEnd
    label.ZIndex = 2
    
    local dot = Instance.new("Frame", btn)
    dot.Size = UDim2.fromOffset(7 * sk_uiScale, 7 * sk_uiScale)
    dot.Position = UDim2.new(1, -10 * sk_uiScale, 0, 3 * sk_uiScale)
    dot.BackgroundColor3 = sk_accent
    dot.BorderSizePixel = 0
    dot.Name = "Dot"
    dot.Visible = isEnabled
    Instance.new("UICorner", dot).CornerRadius = UDim.new(0, 4)
    
    btn.MouseEnter:Connect(function()
        if not Flags["enable skins"] then return end
        if not isEnabled then
            btn.BackgroundColor3 = Color3.fromRGB(28, 28, 40)
        end
    end)
    
    btn.MouseLeave:Connect(function()
        if not Flags["enable skins"] then return end
        if not isEnabled then
            btn.BackgroundColor3 = sk_blankBg
        end
    end)
    
    btn.MouseButton1Click:Connect(function()
        if not Flags["enable skins"] then return end
        if isDefault then
            sk_applySkin(weaponName, nil, false)
        else
            sk_applySkin(weaponName, skinName, true)
        end
        sk_refreshSkins()
        sk_updateAllDots()
    end)
    
    return btn
end

-- Refresh skins function
function sk_refreshSkins()
    for _, v in ipairs(sk_SkinScroll:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end
    if not sk_selectedWeapon then return end
    local skins = ao[sk_selectedWeapon]
    if not skins then return end
    
    local searchLower = sk_skinSearchText:lower()
    local order = 0
    
    if searchLower == "" or ("default"):find(searchLower, 1, true) then
        order = order + 1
        sk_createSkinButton("Default", sk_selectedWeapon, order).Parent = sk_SkinScroll
    end
    
    for _, skin in ipairs(skins) do
        if searchLower == "" or string.lower(skin):find(searchLower, 1, true) then
            order = order + 1
            sk_createSkinButton(skin, sk_selectedWeapon, order).Parent = sk_SkinScroll
        end
    end
end

-- Build weapons function
function sk_buildWeapons()
    sk_weaponButtons = {}
    for _, v in ipairs(sk_WeaponScroll:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end
    
    local weapons = {}
    for weapon in pairs(ao) do
        table.insert(weapons, weapon)
    end
    table.sort(weapons)
    
    local searchLower = sk_weaponSearchText:lower()
    local order = 0
    
    for _, weapon in ipairs(weapons) do
        if searchLower == "" or string.lower(weapon):find(searchLower, 1, true) then
            order = order + 1
            local btn = sk_createWeaponButton(weapon, order)
            btn.Parent = sk_WeaponScroll
            if weapon == sk_selectedWeapon then
                btn.BackgroundColor3 = sk_accent
            end
        end
    end
end

