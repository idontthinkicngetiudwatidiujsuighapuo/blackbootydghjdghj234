-- File functions
local function sk_ensureFolder()
    if not isfolder(sk_configFolder) then
        makefolder(sk_configFolder)
    end
end

local function sk_saveConfig()
    sk_ensureFolder()
    local data = {
        ActiveSkins = sk_settings.ActiveSkins,
        GlassEnabled = sk_settings.GlassEnabled,
        GlassTransparency = sk_settings.GlassTransparency,
    }
    local success, json = pcall(sk_HttpService.JSONEncode, sk_HttpService, data)
    if success then
        writefile(sk_configFile, json)
    end
end

local function sk_loadConfig()
    sk_ensureFolder()
    if not isfile(sk_configFile) then return end
    local success, content = pcall(readfile, sk_configFile)
    if not success or not content or content == "" then return end
    local decoded, data = pcall(sk_HttpService.JSONDecode, sk_HttpService, content)
    if not decoded or type(data) ~= "table" then return end
    if type(data.ActiveSkins) == "table" then sk_settings.ActiveSkins = data.ActiveSkins end
    if type(data.GlassEnabled) == "boolean" then sk_settings.GlassEnabled = data.GlassEnabled end
    if type(data.GlassTransparency) == "number" then sk_settings.GlassTransparency = data.GlassTransparency end
end
sk_loadConfig()

